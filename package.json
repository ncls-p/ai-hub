{
  "name": "ai-hub",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx scripts/migrate.ts && next dev",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:setup": "drizzle-kit generate && tsx scripts/migrate.ts",
    "worker": "tsx src/server/infrastructure/worker/index.ts",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,md}\"",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@ai-sdk/devtools": "^1.0.0",
    "@ai-sdk/gateway": "^4.0.4",
    "@ai-sdk/harness": "^1.0.6",
    "@ai-sdk/harness-claude-code": "^1.0.6",
    "@ai-sdk/harness-codex": "^1.0.6",
    "@ai-sdk/harness-opencode": "^1.0.6",
    "@ai-sdk/harness-pi": "^1.0.6",
    "@ai-sdk/mcp": "^2.0.3",
    "@ai-sdk/openai-compatible": "^3.0.1",
    "@ai-sdk/policy-opa": "^1.0.4",
    "@ai-sdk/provider": "^4.0.0",
    "@ai-sdk/react": "^4.0.5",
    "@ai-sdk/sandbox-just-bash": "^1.0.6",
    "@ai-sdk/sandbox-vercel": "^1.0.6",
    "@ai-sdk/workflow": "^1.0.4",
    "@aws-sdk/client-s3": "^3.800.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@next/env": "^16.2.6",
    "@shadcn/react": "^0.1.0",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@teispace/next-themes": "^0.5.0",
    "@tiptap/react": "^3.24.0",
    "@tiptap/starter-kit": "^3.24.0",
    "@types/pg": "^8.20.0",
    "@types/turndown": "^5.0.6",
    "@upstash/redis": "^1.34.4",
    "ai": "^7.0.4",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.7",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.6.0",
    "jszip": "^3.10.1",
    "katex": "^0.17.0",
    "lucide-react": "^0.545.0",
    "marked": "^18.0.4",
    "next": "16.2.6",
    "next-intl": "^4.13.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.3.1",
    "turndown": "^7.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "pg": "^8.16.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "description": "Production-oriented AI agent hub built with Next.js, Better Auth, Drizzle, and workspace IAM.",
  "author": "Deodis",
  "license": "UNLICENSED",
  "main": "next.config.ts",
  "knip": {
    "ignore": [
      "scripts/sandbox-runner.mjs"
    ]
  }
}
